digraph G {
fontname = "Bitstream Vera Sans" fontsize = 8
node [ fontname = "Bitstream Vera Sans" fontsize = 8 shape = "record" ]
edge [ fontname = "Bitstream Vera Sans" fontsize = 8 ]
_Graph [ label = "{Graph}" ]
_Node [ label = "{Node}" ]
_Edge [ label = "{Edge}" ]
ImportFactory [ label = "{ImportFactory|+ createModule(name : String) : ImportModule\l}" ]
ImportModule [ label = "{ImportModule|+ import(input : String) : Graph\l}" ]
ExportFactory [ label = "{ExportFactory|+ createModule() : ExportModule\l}" ]
ExportModule [ label = "{ExportModule|+ export(g : Graph) : String\l}" ]
CodeGenerator [ label = "{CodeGenerator}" ]
}
